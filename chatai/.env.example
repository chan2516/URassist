# URassist Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# API KEYS & CREDENTIALS
# ============================================

# Google Gemini API Key
# Get it from: https://aistudio.google.com/
GEMINI_API_KEY=

# HugChat Credentials (Optional)
# Account: https://huggingface.co/
HUGCHAT_EMAIL=
HUGCHAT_PASSWORD=

# ============================================
# ASSISTANT CONFIGURATION
# ============================================

# Name of your AI Assistant
ASSISTANT_NAME=jarvis

# Enable offline fallback mode
ENABLE_OFFLINE_FALLBACK=true

# Enable wake word/hotword detection
# Note: Requires Porcupine access key
ENABLE_HOTWORD=false

# ============================================
# AUDIO CONFIGURATION
# ============================================

# Audio device index (use 0 for default)
# Find your device: python -c "import sounddevice; print(sounddevice.query_devices())"
AUDIO_DEVICE_INDEX=0

# Audio sample rate (Hz)
AUDIO_SAMPLE_RATE=16000

# Audio channels
AUDIO_CHANNELS=1

# ============================================
# SERVER CONFIGURATION
# ============================================

# Flask/Eel server host
SERVER_HOST=localhost

# Flask/Eel server port
SERVER_PORT=8000

# Flask debug mode (set to False in production)
FLASK_DEBUG=false

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database file path
DATABASE_PATH=commands.db

# Enable database logging
DB_LOGGING=false

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=urassist.log

# ============================================
# OPTIONAL FEATURES
# ============================================

# Enable command history
ENABLE_HISTORY=true

# Enable statistics tracking
ENABLE_STATS=true

# Enable error reporting
ENABLE_ERROR_REPORTING=true

# ============================================
# PERFORMANCE TUNING
# ============================================

# Max audio buffer size
MAX_AUDIO_BUFFER=10000

# API request timeout (seconds)
API_TIMEOUT=10

# Cache responses (seconds)
CACHE_DURATION=3600

# ============================================
# DEVELOPMENT
# ============================================

# Development mode (more verbose output)
DEV_MODE=false

# Show debug information
DEBUG=false

# Test mode (uses mock data)
TEST_MODE=false
